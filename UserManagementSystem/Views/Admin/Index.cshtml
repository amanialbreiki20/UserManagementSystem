@model List<UserManagementSystem.Models.User>

<div class="container mt-5">
    <div class="card shadow border-0" style="border-radius: 20px;">
        <div class="card-body p-5">

            <h3 class="fw-bold mb-4" style="color: #0d6efd;">👥 Admin Panel</h3>

            <table class="table table-hover">
                <thead style="background-color: #0d6efd; color: white;">
                    <tr>
                        <th>#</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Joined</th>
                        <th>Admin</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td>@user.FullName</td>
                            <td>@user.Email</td>
                            <td>@user.CreatedAt.ToShortDateString()</td>
                            <td>@(user.IsAdmin ? "✅" : "❌")</td>
                            <td>
                                <a asp-action="DeleteUser" asp-route-id="@user.Id"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Are you sure?')">
                                    🗑️ Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

        </div>
    </div>
</div>