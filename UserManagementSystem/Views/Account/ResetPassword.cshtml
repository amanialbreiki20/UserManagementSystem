@model UserManagementSystem.Models.ResetPasswordViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0" style="border-radius: 20px;">
                <div class="card-body p-5">

                    <h3 class="fw-bold mb-4" style="color: #0d6efd;">🔑 Reset Password</h3>

                    <form asp-action="ResetPassword" method="post">

                        <input type="hidden" asp-for="Token" />

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label fw-bold">New Password</label>
                            <input asp-for="NewPassword" type="password" class="form-control" placeholder="••••••" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ConfirmPassword" class="form-label fw-bold">Confirm Password</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="••••••" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary">Reset Password 🔑</button>
                        </div>

                    </form>

                </div>
            </div>
        </div>
    </div>
</div>