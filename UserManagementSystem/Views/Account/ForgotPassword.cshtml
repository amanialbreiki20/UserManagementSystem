@model UserManagementSystem.Models.ForgotPasswordViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0" style="border-radius: 20px;">
                <div class="card-body p-5">

                    <h3 class="fw-bold mb-2" style="color: #0d6efd;">🔐 Forgot Password</h3>
                    <p class="text-muted mb-4">Enter your email and we'll send you a reset link.</p>

                    <form asp-action="ForgotPassword" method="post">

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-bold">Email</label>
                            <input asp-for="Email" class="form-control" placeholder="example@email.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary">Send Reset Link 📧</button>
                        </div>

                    </form>

                    <div class="text-center mt-3">
                        <a asp-action="Login">Back to Login</a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>